# SignVerify Backend Environment Variables
# Copy this file to `.env` and fill in your absolute secure secrets.

# Core Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/signverify

# Cryptographic Token Management
SECRET_KEY=your_highly_secure_random_jwt_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Twilio OTP Integration (Optional in sandbox mode)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
